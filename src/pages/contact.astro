---
import Layout from '../layouts/Layout.astro';
---

<Layout
	title="Contact Cello"
	description="Talk to Cello about business-only networks, SmartWAN and practical digital resilience options."
>
	<section class="page-hero">
		<div class="page-hero-inner narrow">
			<p class="eyebrow">Contact</p>
			<h1>Talk to the team that owns the outcome.</h1>
			<p class="lead">
				Speak with Cello about reliable business connectivity, service visibility
				and the support your organisation needs around critical networks.
			</p>
		</div>
	</section>

	<section class="section">
		<div class="proof-grid">
			<div class="tile">
				<p class="eyebrow">Phone</p>
				<h2><a href="tel:0800225662">0800 225 662</a></h2>
				<p>Use this for the main Cello conversation path.</p>
			</div>
			<div class="tile">
				<p class="eyebrow">Email</p>
				<h2 class="contact-value contact-value-email">
					<a href="mailto:enquires@cello.co.nz">enquires@cello.co.nz</a>
				</h2>
				<p>Email Cello to discuss connectivity, service assurance or practical digital resilience options.</p>
			</div>
		</div>
	</section>

	<section class="section">
		<div class="split">
			<div class="copy">
				<p class="eyebrow">Offices</p>
				<h2>Local accountability across New Zealand.</h2>
				<p>Auckland, Wellington, Christchurch and Dunedin.</p>
				<ul>
					<li>Network design and operation conversations</li>
					<li>SmartWAN and enterprise connectivity advice</li>
					<li>Visibility, security and operational assurance next steps</li>
				</ul>
			</div>
			<div class="ink-panel">
				<p class="eyebrow">Urgent support</p>
				<p class="quote">Cello's 24/7 NOC is available for critical issues.</p>
				<div class="actions">
					<a class="button" href="mailto:noc@cello.co.nz">Contact support</a>
				</div>
			</div>
		</div>
	</section>
</Layout>
